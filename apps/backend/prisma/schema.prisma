generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ──────────────────────────────────────────────

enum UserRole {
  tenant
  landlord
  admin
  super_admin
  provider
}

enum UserPlan {
  free
  premium
}

enum UnitType {
  apartment
  room
  bed
}

enum ListingStatus {
  draft
  pending_review
  active
  rented
  paused
  rejected
}

enum GenderTarget {
  male
  female
  mixed
  family
}

enum ElectricityType {
  prepaid_card
  old_meter
  modern_meter
}

enum BedStatus {
  available
  rented
}

enum BedType {
  single
  double
}

enum RequestStatus {
  pending
  accepted
  rejected
  completed
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  PHONE_VERIFICATION
}

enum IdentityStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum NotificationType {
  SYSTEM
  REQUEST
  REVIEW
  PAYMENT
  CHAT
  ALERT
}

// ── MODELS ─────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  name               String
  phone              String    @unique
  email              String?   @unique
  passwordHash       String?
  role               UserRole  @default(tenant)
  plan               UserPlan  @default(free)
  planExpiresAt      DateTime?
  nationalIdEnc      String?
  nationalIdVerified Boolean        @default(false)
  identityStatus     IdentityStatus @default(NONE)
  avatarUrl          String?
  avatarPublicId     String?
  idCardPublicId     String?
  emailVerifiedAt    DateTime?
  phoneVerifiedAt    DateTime?
  isActive           Boolean   @default(true)
  ratingAvg          Float     @default(0)
  reviewsCount       Int       @default(0)
  otpChannel         OtpChannel @default(EMAIL)
  telegramChatId     String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt


  // Relations
  listings          Listing[]
  requests          ViewingRequest[]
  reviewsGiven      Review[]           @relation("ReviewsGiven")
  reviewsReceived   Review[]           @relation("ReviewsReceived")
  alerts            Alert[]
  subscriptions     Subscription[]
  sentMessages      ChatMessage[]      @relation("SentMessages")
  conversationParticipants ConversationParticipant[]
  verificationCodes VerificationCode[]
  deviceSessions    DeviceSession[]
  favorites         Favorite[]
  searchHistory     SearchHistory[]
  viewedListings    ViewedListing[]
  notifications     Notification[]
  currentListingRentals Listing[]        @relation("ListingCurrentTenant")
  contractsAsLandlord RentalContract[] @relation("ContractsAsLandlord")
  contractsAsTenant   RentalContract[] @relation("ContractsAsTenant")
  pushSubscriptions   PushSubscription[]
  communityRatingAvg    Float                  @default(0)
  communityReviewsCount Int                    @default(0)
  communityPosts        CommunityPost[]
  communityAlerts       CommunityAlert[]
  communityParticipants CommunityParticipant[]
  communityReportsMade  CommunityReport[]
  communityReviewsGiven   CommunityReview[]  @relation("CommunityReviewsGiven")
  communityReviewsReceived CommunityReview[]  @relation("CommunityReviewsReceived")

  @@map("users")
}

model Listing {
  id                     String          @id @default(cuid())
  landlordId             String
  title                  String
  description            String?
  unitType               UnitType
  price                  Int
  securityDeposit        Int             @default(0)
  includesBills          Boolean         @default(false)
  electricityType        ElectricityType @default(modern_meter)
  totalBeds              Int?
  availableBeds          Int?
  genderTarget           GenderTarget    @default(mixed)
  governorate            String
  district               String
  address                String
  lat                    Float
  lng                    Float
  status                 ListingStatus   @default(draft)
  amenities              String[]
  roommateFeatureEnabled Boolean         @default(false)
  viewCount              Int             @default(0)
  currentTenantId        String?
  rentedSince            DateTime?
  rentedUntil            DateTime?
  isFeatured             Boolean         @default(false)
  rejectionReason        String?
  // ── Soft Delete ─────────────────────────────────────────
  isDeleted              Boolean         @default(false)
  deletedAt              DateTime?
  deletedById            String?
  deletedByRole          UserRole?
  deletedReason          String?
  statusBeforeDelete     ListingStatus?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  // Relations
  landlord      User             @relation(fields: [landlordId], references: [id])
  currentTenant User?            @relation("ListingCurrentTenant", fields: [currentTenantId], references: [id])
  images        ListingImage[]
  beds          ListingBed[]
  requests      ViewingRequest[]
  reviews       Review[]
  favorites     Favorite[]
  viewedBy      ViewedListing[]
  auditLogs     ListingAuditLog[]
  contracts     RentalContract[]

  @@index([status, governorate, district])
  @@index([price])
  @@index([genderTarget])
  @@index([landlordId])
  @@index([currentTenantId])
  @@index([isDeleted])
  @@map("listings")
}

model ListingAuditLog {
  id                   String   @id @default(cuid())
  listingId            String
  listingTitleSnapshot String
  actorId              String
  actorRole            UserRole
  actorName            String
  action               String   // soft_delete | restore | delete_images | permanent_delete
  detail               String?
  createdAt            DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([actorId])
  @@map("listing_audit_logs")
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  s3Key     String
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

model ListingBed {
  id              String    @id @default(cuid())
  listingId       String
  bedNumber       Int
  bedType         BedType   @default(single)
  status          BedStatus @default(available)
  currentTenantId String?
  rentedSince     DateTime?
  rentedUntil     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  contracts       RentalContract[]

  @@unique([listingId, bedNumber])
  @@map("listing_beds")
}

model ViewingRequest {
  id            String        @id @default(cuid())
  tenantId      String
  listingId     String
  status        RequestStatus @default(pending)
  preferredDate DateTime
  message       String?
  specialty     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant  User    @relation(fields: [tenantId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])
  contract RentalContract?

  @@map("viewing_requests")
}

model Review {
  id         String   @id @default(cuid())
  tenantId   String
  landlordId String
  listingId  String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  tenant   User    @relation("ReviewsGiven", fields: [tenantId], references: [id])
  landlord User    @relation("ReviewsReceived", fields: [landlordId], references: [id])
  listing  Listing @relation(fields: [listingId], references: [id])

  @@map("reviews")
}

model Alert {
  id           String        @id @default(cuid())
  tenantId     String
  governorate  String?
  district     String?
  maxPrice     Int?
  unitType     UnitType?
  genderTarget GenderTarget?
  specialty    String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())

  tenant User @relation(fields: [tenantId], references: [id])

  @@map("alerts")
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  plan      UserPlan
  status    String   @default("active")
  startedAt DateTime @default(now())
  expiresAt DateTime
  paymobRef String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}

model Blacklist {
  id             String   @id @default(cuid())
  nationalIdHash String?  @unique
  phone          String?  @unique
  reason         String
  bannedBy       String
  createdAt      DateTime @default(now())

  @@map("blacklist")
}

model VerificationCode {
  id        String           @id @default(cuid())
  userId    String?
  email     String?
  phone     String?
  type      VerificationType
  codeHash  String
  attempts  Int              @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verification_codes")
}

model DeviceSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  deviceName       String?
  ip               String?
  lastSeen         DateTime @default(now())
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_sessions")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  notes     String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@map("favorites")
}

model SearchHistory {
  id           String        @id @default(cuid())
  userId       String
  query        String?
  governorate  String?
  district     String?
  minPrice     Int?
  maxPrice     Int?
  unitType     UnitType?
  genderTarget GenderTarget?
  specialty    String?
  createdAt    DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("search_history")
}

model ViewedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  viewCount Int      @default(1)
  viewedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@map("viewed_listings")
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  body       String
  entityType String?
  entityId   String?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String?
  action    String
  entity    String
  entityId  String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

enum ConversationType {
  PRIVATE
  SUPPORT
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  CLOSED
}

enum ParticipantRole {
  USER
  SUPPORT
}

model Conversation {
  id             String             @id @default(cuid())
  type           ConversationType   @default(PRIVATE)
  status         ConversationStatus @default(ACTIVE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  // Moderation fields
  blockedAt      DateTime?
  blockedBy      String?
  blockReason    String?

  // Intelligent last message indicators (simplified as scalars)
  lastMessageId  String?
  lastMessageAt  DateTime?

  participants   ConversationParticipant[]
  messages       ChatMessage[]

  @@map("conversations")
}

model ConversationParticipant {
  conversationId String
  userId         String
  role           ParticipantRole @default(USER)
  joinedAt       DateTime        @default(now())
  lastReadAt     DateTime        @default(now())
  isMuted        Boolean         @default(false)

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@map("conversation_participants")
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// ── RENTAL CONTRACT ENUMS & MODEL ────────────────────────

enum ContractStatus {
  active
  expired
  terminated
  renewed
}

enum PaymentCycle {
  monthly
  quarterly
  yearly
}

enum TerminationReason {
  tenant_request
  landlord_request
  violation
  mutual_agreement
  other
}

enum ContractCreatedBy {
  VIEWING_REQUEST
  MANUAL
  AUTO_RENEW
  MIGRATION
}

model RentalContract {
  id               String            @id @default(cuid())
  contractNumber   String            @unique
  
  listingId        String
  landlordId       String
  tenantId         String
  bedId            String?

  viewingRequestId String?           @unique
  viewingRequest   ViewingRequest?   @relation(fields: [viewingRequestId], references: [id], onDelete: SetNull)

  createdByType    ContractCreatedBy @default(VIEWING_REQUEST)

  monthlyRent      Int
  securityDeposit  Int               @default(0)
  paymentCycle     PaymentCycle      @default(monthly)
  currency         String            @default("EGP")

  startDate        DateTime
  endDate          DateTime
  actualCheckout   DateTime?

  isAutoRenew      Boolean           @default(false)

  status             ContractStatus     @default(active)
  terminationReason  TerminationReason?
  terminationNotes   String?

  notes            String?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  listing  Listing     @relation(fields: [listingId],  references: [id])
  landlord User        @relation("ContractsAsLandlord", fields: [landlordId], references: [id])
  tenant   User        @relation("ContractsAsTenant",   fields: [tenantId],   references: [id])
  bed      ListingBed? @relation(fields: [bedId],       references: [id])

  @@index([listingId])
  @@index([landlordId])
  @@index([tenantId])
  @@index([status])
  @@index([endDate])
  @@index([isAutoRenew])
  @@map("rental_contracts")
}

enum OtpChannel {
  EMAIL
  TELEGRAM
}

model PendingTelegramLink {
  id         String    @id @default(cuid())
  identifier String    @unique
  linkCode   String    @unique
  chatId     String?
  linkedAt   DateTime?
  usedAt     DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([linkCode])
  @@index([identifier])
  @@map("pending_telegram_links")
}

model PushSubscription {
  id          String    @id @default(cuid())
  userId      String
  endpoint    String    @unique
  p256dh      String
  auth        String
  deviceName  String?
  browser     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model CommunityCategory {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String
  icon      String   // e.g. "⚽", "🎮", "☕"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts     CommunityPost[]
  alerts    CommunityAlert[]

  @@map("community_categories")
}

enum CommunityPostStatus {
  ACTIVE
  ARCHIVED
  CANCELLED
  BLOCKED
}

enum CommunityParticipantStatus {
  PENDING
  ACCEPTED
  REJECTED
  LEFT
  EXPIRED
}

enum GenderPreference {
  MALES_ONLY
  FEMALES_ONLY
  ALL
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE
  FAKE
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model CommunityPost {
  id               String              @id @default(cuid())
  userId           String
  title            String
  description      String
  categoryId       String
  governorateId    String
  cityId           String
  genderPreference GenderPreference    @default(ALL)
  maxParticipants  Int
  eventDate        DateTime
  timeSlot         String              
  status           CommunityPostStatus @default(ACTIVE)
  isDeleted        Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         CommunityCategory   @relation(fields: [categoryId], references: [id])
  participants     CommunityParticipant[]
  reports          CommunityReport[]
  reviews          CommunityReview[]

  @@index([userId])
  @@index([categoryId])
  @@index([governorateId, cityId])
  @@index([status])
  @@index([eventDate])
  @@map("community_posts")
}

model CommunityParticipant {
  id        String                     @id @default(cuid())
  postId    String
  userId    String
  status    CommunityParticipantStatus @default(PENDING)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  post      CommunityPost              @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("community_participants")
}

model CommunityAlert {
  id               String            @id @default(cuid())
  userId           String
  categoryId       String
  governorateId    String
  cityId           String
  genderPreference GenderPreference  @default(ALL)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category         CommunityCategory @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@map("community_alerts")
}

model CommunityReview {
  id          String   @id @default(cuid())
  postId      String
  authorId    String
  targetId    String   
  rating      Int      
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post        CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author      User          @relation("CommunityReviewsGiven", fields: [authorId], references: [id], onDelete: Cascade)
  target      User          @relation("CommunityReviewsReceived", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([postId, authorId])
  @@map("community_reviews")
}

model CommunityReport {
  id         String       @id @default(cuid())
  postId     String
  reporterId String
  reason     ReportReason
  details    String?      
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter   User          @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@map("community_reports")
}

