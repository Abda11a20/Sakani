# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sakani_db"

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── App ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="production"
FRONTEND_URL="https://your-domain.com"

# ─── Email Provider ──────────────────────────────────────────────────────────
# اختر المزود: gmail | resend
EMAIL_PROVIDER="gmail"

# ─── Gmail SMTP ──────────────────────────────────────────────────────────────
MAIL_HOST="smtp.gmail.com"
MAIL_PORT="587"
MAIL_SECURE="false"
MAIL_USER="sakani.app.otp@gmail.com"
MAIL_PASSWORD="PUT_YOUR_APP_PASSWORD_HERE"
MAIL_FROM="سَكني | Sakani <sakani.app.otp@gmail.com>"

# ─── Email (Resend) — يظل موجوداً للتبديل السريع ─────────────────────────────
# EMAIL_PROVIDER="resend"
RESEND_API_KEY="re_your-resend-api-key"

# ─── Cloudinary ─────────────────────────────────────────────────────────────
STORAGE_PROVIDER="cloudinary"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Pusher ──────────────────────────────────────────────────────────────────
PUSHER_APP_ID="your-app-id"
PUSHER_APP_KEY="your-app-key"
PUSHER_APP_SECRET="your-app-secret"
PUSHER_APP_CLUSTER="mt1"

# ─── Encryption ──────────────────────────────────────────────────────────────
ENCRYPTION_KEY="exactly-32-characters-long-key!!"

# ─── Payments (Paymob) ───────────────────────────────────────────────────────
SUBSCRIPTIONS_ENABLED=false
PAYMOB_API_KEY="your-paymob-api-key"
PAYMOB_INTEGRATION_ID="your-integration-id"
PAYMOB_HMAC_SECRET="your-hmac-secret"

# ─── Telegram Bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-here"
TELEGRAM_WEBHOOK_SECRET="your-telegram-webhook-secret-token-here"
TELEGRAM_WEBHOOK_URL="https://your-ngrok-or-domain-url"
